* text=auto

# Windows scripts must keep CRLF for cmd.exe / PowerShell
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Python and config: LF
*.py text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.md text eol=lf
*.txt text eol=lf

# Binary
*.sqlite3 binary
*.png binary
*.jpg binary
*.pdf binary
