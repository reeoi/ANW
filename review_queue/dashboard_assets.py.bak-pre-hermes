  flex-wrap: wrap;
}
.page-header h2 {
  margin: 0;
  font-size: 1.85rem;
  font-weight: 800;
  letter-spacing: -0.03em;
  color: var(--text);
}
.page-header .meta { color: var(--text-muted); font-size: 0.875rem; }

.banner {
  background: var(--primary-soft);
  color: var(--primary-strong);
  border: 1px solid var(--primary);
  padding: 1rem 1.25rem;
  border-radius: var(--radius);
  margin-bottom: 1.5rem;
  font-weight: 500;
}
.banner.hidden { display: none !important; }
.section { display: none; animation: fadeIn 0.3s cubic-bezier(0.16, 1, 0.3, 1); }
@keyframes fadeIn { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: translateY(0); } }
.section.active { display: block; }

.card-glass {
  background: #1e293b; border: 1px solid rgba(255,255,255,0.05);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 1.5rem;
  box-shadow: var(--shadow);
  transition: all 0.2s ease;
}
[data-theme='dark'] .card-glass { backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px); }
.card-glass:hover { transform: translateY(-2px); box-shadow: var(--shadow-lg); border-color: var(--primary); }

.cards {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
  gap: 1.25rem;
  margin-bottom: 2rem;
}
.card {
  background: var(--panel);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 1.5rem;
  box-shadow: var(--shadow);
  transition: all 0.2s;
}
.card:hover { transform: translateY(-2px); box-shadow: var(--shadow-lg); }
.card .label { color: var(--text-muted); font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; }
.card .value { font-size: 1.85rem; font-weight: 800; margin-top: 0.5rem; color: var(--text); }
.card.warn .value { color: var(--warning); }
.card.bad .value { color: var(--danger); }
.card.ok .value { color: var(--success); }

.panel {
  background: var(--panel);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 1.75rem;
  box-shadow: var(--shadow);
  margin-bottom: 1.5rem;
}
.panel h3 { margin: 0 0 1.25rem; font-size: 1.35rem; font-weight: 800; color: var(--text); letter-spacing: -0.02em; }
.panel p { margin: 0 0 1rem; color: var(--text-muted); }

form.grid { display: grid; gap: 1.25rem; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); }
form.grid .full { grid-column: 1 / -1; }
label { display: flex; flex-direction: column; gap: 0.5rem; font-size: 0.875rem; font-weight: 600; color: var(--text); }
input, textarea, select {
  font: inherit;
  padding: 0.75rem 1rem;
  border: 1px solid var(--border);
  border-radius: var(--radius-sm);
  background: var(--panel);
  color: var(--text);
  width: 100%;
  transition: all 0.2s;
}
input:focus, textarea:focus, select:focus {
  outline: none;
  border-color: var(--primary);
  box-shadow: 0 0 0 4px var(--primary-soft);
}
textarea { min-height: 240px; resize: vertical; }

.actions { display: flex; flex-wrap: wrap; gap: 0.75rem; }
button {
  font: inherit;
  padding: 0.75rem 1.5rem;
  border-radius: var(--radius-sm);
  border: 1px solid transparent;
  cursor: pointer;
  background: var(--panel-soft);
  color: var(--text);
  font-weight: 600;
  transition: all 0.2s cubic-bezier(0.16, 1, 0.3, 1);
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 0.6rem;
}
button:hover { background: var(--border); transform: translateY(-1px); }
button:active { transform: translateY(0); scale: 0.98; }
button:disabled { opacity: 0.5; cursor: not-allowed; transform: none !important; }
button.primary { background: rgba(79, 70, 229, 0.2); border-left: 3px solid var(--primary); color: var(--primary); font-weight: 600; box-shadow: 0 4px 6px -1px var(--primary-soft); }
button.primary:hover { background: var(--primary-strong); box-shadow: 0 10px 15px -3px var(--primary-soft); color: #fff; }
button.success { background: var(--success); color: var(--primary); font-weight: 600; }
button.danger { background: var(--danger); color: var(--primary); font-weight: 600; }
button.warning { background: var(--warning); color: var(--primary); font-weight: 600; }
button.ghost { background: transparent; border: 1px solid var(--border); }
button.ghost:hover { background: var(--panel-soft); border-color: var(--text-muted); }
button.tiny { padding: 0.4rem 0.8rem; font-size: 0.8rem; }

table { width: 100%; border-collapse: collapse; font-size: 0.9rem; }
table th, table td { padding: 1.1rem 1rem; border-bottom: 1px solid var(--border); text-align: left; vertical-align: middle; }
table th { color: var(--text-muted); font-weight: 700; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.08em; background: var(--panel-soft); }
table tr:hover { background: var(--panel-soft); }

.badge {
  display: inline-flex;
  align-items: center;
  padding: 0.3rem 0.85rem;
  border-radius: 9999px;
  font-size: 0.75rem;
  font-weight: 700;
  background: var(--panel-soft);
  color: var(--text-muted);
  text-transform: capitalize;
}
.badge-indigo { background: var(--primary-soft); color: var(--primary); padding: 0.2rem 0.6rem; border-radius: 6px; font-weight: 600; font-size: 0.75rem; }
.badge.pending { background: #fef3c7; color: #92400e; }
.badge.needs_human { background: #fee2e2; color: #991b1b; }
.badge.approved { background: #dcfce7; color: #14532d; }
.badge.published { background: #dbeafe; color: #1e3a8a; }
.badge.rejected { background: var(--panel-soft); color: var(--text-muted); }
.badge.publish_paused { background: #fef3c7; color: #92400e; }
.badge.publish_failed, .badge.failed { background: #fee2e2; color: #7f1d1d; }

pre.log {
  white-space: pre-wrap;
  background: #0f172a;
  color: #e2e8f0;
  padding: 1.5rem;
  border-radius: var(--radius);
  max-height: 520px;
  overflow: auto;
  font-size: 0.85rem;
  font-family: 'JetBrains Mono', 'Fira Code', monospace;
  line-height: 1.6;
}
#toasts {
  position: fixed;
  right: 2rem;
  bottom: 2rem;
  display: flex;
  flex-direction: column;
  gap: 1rem;
  z-index: 9999;
}
.toast {
  background: var(--panel);
  color: var(--text);
  padding: 1rem 1.5rem;
  border-radius: var(--radius);
  box-shadow: var(--shadow-lg);
  max-width: 420px;
  font-size: 0.95rem;
  font-weight: 600;
  border: 1px solid var(--border);
  display: flex;
  align-items: center;
  gap: 0.75rem;
  animation: slideIn 0.4s cubic-bezier(0.16, 1, 0.3, 1);
}
@keyframes slideIn { from { transform: translateX(100%); opacity: 0; } to { transform: translateX(0); opacity: 1; } }
.toast.success { border-left: 4px solid var(--success); }
.toast.error { border-left: 4px solid var(--danger); }
.toast.warn { border-left: 4px solid var(--warning); }

.modal-backdrop {
  display: none;
  position: fixed;
  inset: 0;
  background: rgba(15, 23, 42, 0.7);
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
  align-items: center;
  justify-content: center;
  padding: 2rem;
  z-index: 1000;
}
.modal-backdrop.show { display: flex; }
.modal {
  background: var(--panel);
  border: 1px solid var(--border);
  border-radius: 20px;
  width: min(900px, 100%);
  max-height: 90vh;
  overflow: auto;
  padding: 2.5rem;
  box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
  animation: modalIn 0.4s cubic-bezier(0.16, 1, 0.3, 1);
}
@keyframes modalIn { from { transform: scale(0.95) translateY(10px); opacity: 0; } to { transform: scale(1) translateY(0); opacity: 1; } }
.modal h3 { margin-top: 0; font-size: 1.75rem; font-weight: 800; letter-spacing: -0.02em; }

.progress {
  position: relative;
  height: 12px;
  background: var(--panel-soft);
  border-radius: 999px;
  overflow: hidden;
  margin: 0.5rem 0 1rem;
}
.progress > span {
  display: block;
  height: 100%;
  background: rgba(79, 70, 229, 0.2); border-left: 3px solid var(--primary);
  transition: width 0.6s cubic-bezier(0.16, 1, 0.3, 1);
}

.kv-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
  gap: 1rem 2rem;
  font-size: 0.95rem;
}
.kv-grid div { display: flex; justify-content: space-between; gap: 1.5rem; padding: 0.75rem 0; border-bottom: 1px solid var(--border); }
.kv-grid div span:first-child { font-weight: 600; color: var(--text-muted); }
.kv-grid div span:last-child { color: var(--text); font-family: 'JetBrains Mono', monospace; font-weight: 500; }

.mode-banner {
  display: flex;
  align-items: center;
  gap: 1rem;
  padding: 1.25rem 1.5rem;
  border-radius: var(--radius);
  margin-bottom: 2rem;
  font-size: 1.05rem;
  font-weight: 700;
  border: 1px solid var(--border);
  box-shadow: var(--shadow);
}
.mode-banner.mode-dryrun { background: var(--primary-soft); color: var(--primary-strong); border-left: 6px solid var(--primary); }
.mode-banner.mode-live { background: var(--warning-soft); color: #9a3412; border-left: 6px solid var(--warning); }

.mode-banner .mode-icon { font-size: 1.25rem; }
.mode-banner .mode-text { flex: 1; }
.mode-banner button { background: #fff; border: 1px solid rgba(0,0,0,0.05); box-shadow: 0 1px 2px rgba(0,0,0,0.05); }

/* ---------- Settings ---------- */
.settings-section { max-width: 1000px; }
.settings-group {
  background: var(--panel);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  margin-bottom: 1rem;
  box-shadow: var(--shadow);
  overflow: hidden;
}
.settings-group > summary {
  list-style: none;
  cursor: pointer;
  padding: 1.25rem 1.5rem;
  display: flex;
  align-items: center;
  gap: 1rem;
  font-weight: 700;
  font-size: 1.1rem;
  background: #fff;
  transition: background 0.2s;
}
.settings-group > summary:hover { background: #f8fafc; }
.settings-group > summary::-webkit-details-marker { display: none; }
.settings-group > summary::before {
  content: "→";
  display: inline-block;
  color: var(--muted);
  transition: transform 0.2s;
}
.settings-group[open] > summary::before { transform: rotate(90deg); }
.settings-group .group-body { padding: 0 1.5rem 1.5rem; display: flex; flex-direction: column; gap: 1.25rem; }
.settings-group .group-actions {
  display: flex;
  gap: 0.75rem;
  justify-content: flex-end;
  border-top: 1px solid var(--border);
  padding-top: 1.25rem;
  margin-top: 0.5rem;
}
.settings-row { display: grid; grid-template-columns: 14rem 1fr; gap: 0.75rem 1.5rem; align-items: center; }
.settings-row > label { font-size: 0.9375rem; font-weight: 600; color: #475569; }
.settings-row .control-inline { display: flex; gap: 0.75rem; align-items: center; flex-wrap: wrap; }
.settings-advanced {
  margin-top: 0.75rem;
  border-top: 1px dashed var(--border);
  padding-top: 1rem;
}
.settings-advanced > summary {
  list-style: none;
  cursor: pointer;
  font-size: 0.875rem;
  font-weight: 700;
  color: var(--primary);
  display: flex;
  align-items: center;
  gap: 0.5rem;
}
.settings-advanced > summary:hover { text-decoration: underline; }

/* ---------- Status Cards ---------- */
.status-cards {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
  gap: 1rem;
  margin-bottom: 2rem;
}
.card-status {
  position: relative;
  background: var(--panel);
  border: 1px solid var(--border);
  border-top: 4px solid var(--success);
  border-radius: var(--radius);
  padding: 1.25rem;
  box-shadow: var(--shadow);
  cursor: pointer;
  transition: all 0.2s;
}
.card-status:hover { transform: translateY(-4px); box-shadow: var(--shadow-lg); }
.card-status .card-icon {
  position: absolute;
  top: 1.25rem;
  right: 1.25rem;
  font-size: 1.5rem;
  opacity: 0.2;
}
.card-status .card-label { color: var(--muted); font-size: 0.75rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.1em; }
.card-status .card-value { font-size: 1.5rem; font-weight: 800; margin-top: 0.5rem; color: #0f172a; }
.card-status .card-detail { color: var(--muted); font-size: 0.875rem; margin-top: 0.5rem; line-height: 1.4; }
.card-status.level-ok { border-top-color: var(--success); }
.card-status.level-warn { border-top-color: var(--warning); }
.card-status.level-warn .card-value { color: var(--warning); }
.card-status.level-danger { border-top-color: var(--danger); }
.card-status.level-danger .card-value { color: var(--danger); }

.story-dryrun {
  border-left: 3px solid #93c5fd !important;
  background: linear-gradient(90deg, rgba(219,234,254,0.4) 0%, rgba(255,255,255,0) 60%) !important;
}
.dryrun-marker {
  display: inline-block;
  margin-right: 0.25rem;
  padding: 0 0.35rem;
  font-size: 0.7rem;
  background: #dbeafe;
  color: #1e40af;
  border-radius: 4px;
  font-weight: 600;
  vertical-align: middle;
}

#critical-banner {
  position: relative;
  background: #fee2e2;
  color: #7f1d1d;
  border: 1px solid #fca5a5;
  border-left: 4px solid var(--danger);
  border-radius: 10px;
  padding: 0.75rem 1rem;
  margin-bottom: 1rem;
  display: flex;
  flex-direction: column;
  gap: 0.4rem;
}
#critical-banner.hidden { display: none; }
#critical-banner .crit-row { display: flex; gap: 0.6rem; align-items: center; }
#critical-banner .crit-icon { font-size: 1.1rem; }
#critical-banner .crit-text { flex: 1; font-weight: 500; }
#critical-banner button.dismiss { background: rgba(255,255,255,0.6); border: 1px solid rgba(127,29,29,0.2); color: #7f1d1d; }

#console-panel .console-actions { display: flex; gap: 0.6rem; align-items: center; flex-wrap: wrap; margin-bottom: 0.8rem; }
#console-panel .console-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(160px, 1fr)); gap: 0.6rem; }
#console-panel .console-cell { background: var(--panel-soft); padding: 0.6rem 0.8rem; border-radius: 6px; }
#console-panel .console-label { font-size: 0.78rem; color: var(--muted); margin-bottom: 0.25rem; }
#console-panel .console-value { font-size: 1rem; font-weight: 500; }

#inbox-panel { margin-top: 1rem; }
#inbox-panel .inbox-head { display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.5rem; }
#inbox-panel h3 { margin: 0; }
#inbox-panel #inbox-summary { color: var(--muted); font-size: 0.85rem; font-weight: 400; }
.inbox-row {
  display: grid;
  grid-template-columns: 60px 1fr auto auto auto;
  align-items: center;
  gap: 0.6rem;
  padding: 0.55rem 0.6rem;
  border-radius: 6px;
  cursor: pointer;
  transition: background 0.12s;
}
.inbox-row:hover { background: var(--panel-soft); }
.inbox-row + .inbox-row { border-top: 1px solid var(--border); }
.inbox-row .inbox-id { color: var(--muted); font-family: ui-monospace, Consolas, monospace; font-size: 0.85rem; }
.inbox-row .inbox-title { font-weight: 500; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.inbox-row .inbox-meta { color: var(--muted); font-size: 0.78rem; }
.inbox-row .inbox-badge {
  font-size: 0.74rem;
  padding: 0.15rem 0.5rem;
  border-radius: 999px;
  font-weight: 500;
  white-space: nowrap;
}
.inbox-badge.pending { background: #fff7e0; color: #a06000; }
.inbox-badge.needs_human { background: #fdebd0; color: #8a4a00; }
.inbox-badge.approved { background: #d6f4dd; color: #196933; }
.inbox-badge.published { background: #d2eafe; color: #1d4ed8; }
.inbox-badge.publish_paused { background: #ffe5e5; color: #a40000; }
.inbox-badge.failed { background: #f5d6d6; color: #800; }
.inbox-badge.rejected { background: #e0e0e0; color: #555; }
.inbox-badge.cancelled { background: #ececec; color: #666; }
.inbox-row .inbox-actions { display: flex; gap: 0.35rem; }
.step-editor-row:hover { background: var(--hover); }
.inbox-row .inbox-actions button {
  font-size: 0.78rem;
  padding: 0.25rem 0.6rem;
  border-radius: 4px;
  cursor: pointer;
}
.inbox-empty { color: var(--muted); padding: 1rem; text-align: center; }

/* 详情模态（轻量复用 story-modal 样式） */
#inbox-detail-modal { background: rgba(15,23,42,0.5); position: fixed; inset: 0; display: none; align-items: center; justify-content: center; z-index: 9999; }
#inbox-detail-modal.show { display: flex; }
#inbox-detail-modal .modal-card { background: var(--panel); border-radius: 8px; max-width: 900px; width: 100%; max-height: 80vh; display: flex; flex-direction: column; box-shadow: 0 10px 30px rgba(0,0,0,0.25); }
#inbox-detail-modal .modal-head { display: flex; justify-content: space-between; align-items: center; padding: 0.7rem 1rem; border-bottom: 1px solid rgba(0,0,0,0.08); }
