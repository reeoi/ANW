}

.sidebar .footnote {
  margin-top: auto;
  padding: 1.5rem 0.5rem 0;
  font-size: 0.75rem;
  color: #64748b;
  border-top: 1px solid rgba(255,255,255,0.05);
}
.theme-toggle {
  margin-top: auto;
  padding: 0.75rem 1rem;
  margin-bottom: 1rem;
  border-radius: var(--radius-sm);
  cursor: pointer;
  display: flex;
  align-items: center;
  gap: 0.75rem;
  font-size: 0.9rem;
  font-weight: 500;
  color: var(--sidebar-text);
  border: 1px solid rgba(255,255,255,0.1);
