  // ---------- Notification stream (Phase 2) ----------
  let notifSource = null;
  function startNotificationStream() {
    if (typeof EventSource === 'undefined') return;
    try {
      notifSource = new EventSource('/api/notifications/stream');
      notifSource.onmessage = (event) => {
        let payload;
        try { payload = JSON.parse(event.data); } catch (_e) { return; }
        if (!payload || payload.dismissed) return;
        const sev = payload.severity || 'info';
        const ttl = sev === 'critical' ? 0 : (sev === 'warning' ? 10000 : 3500);
        const message = (payload.title ? '[' + payload.title + '] ' : '') + (payload.message || '');
        if (sev === 'critical') {
          showCriticalBanner(payload);
        } else {
          const cls = sev === 'warning' ? 'warn' : 'success';
          toast(message, cls, ttl);
        }
      };
      notifSource.onerror = () => {
        // EventSource 自带重连;只在永久关闭后清理
        if (notifSource && notifSource.readyState === EventSource.CLOSED) notifSource = null;
      };
    } catch (_e) { /* 忽略,前端无致命依赖 */ }
  }

  function showCriticalBanner(payload) {
    const banner = $('critical-banner');
    if (!banner) return;
    banner.classList.remove('hidden');
    const row = document.createElement('div');
    row.className = 'crit-row';
    row.dataset.notifId = payload.id || '';
    row.innerHTML =
      '<span class="crit-icon">🚨</span>' +
      '<span class="crit-text">' + escapeHtml(payload.title || '') + ' — ' + escapeHtml(payload.message || '') + '</span>' +
      '<button class="dismiss tiny">关闭</button>';
    banner.appendChild(row);
    row.querySelector('button.dismiss').addEventListener('click', async () => {
      try { await api('/api/notifications/dismiss/' + payload.id, { method: 'POST' }); } catch (_e) {}
      row.remove();
      if (banner.children.length === 0) banner.classList.add('hidden');
    });
  }

