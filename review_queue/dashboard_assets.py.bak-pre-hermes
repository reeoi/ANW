  const BUILTIN_LABELS = {
    phase_0: '📌 选题', phase_1: '📖 框架', phase_2: '📋 大纲',
    phase_3: '✍ 正文', phase_4: '✨ 精修', phase_5: '🧹 去AI味',
    phase_5_5: '🔍 朱雀检测', phase_6: '📑 分章'
  };
  const BUILTIN_DESCRIPTIONS = {
    phase_0: '从题材池选种子，生成选题卡片和人物设定',
    phase_1: '基于选题生成故事框架、简介、情绪曲线',
    phase_2: '拆分小节大纲，规划每节的情节点',
    phase_3: '逐节生成正文并合稿为完整故事',
    phase_4: '整体精修润色，提升语言质量',
    phase_5: '去AI味：替换AI常用词、打破工整句式',
    phase_5_5: '腾讯朱雀AI检测闭环：检测→不通过→LLM重写→再检测（最多3轮）',
    phase_6: '将短篇拆分为多个章节并生成章节标题'
  };
  var _currentSteps = [];  // in-memory step list for current preset
  var _generatedStep = null;  // last LLM-generated step

  // ── Preset switcher ──
  async function loadPresetSwitcher() {
    var sel = $('preset-switcher');
    if (!sel) return;
    try {
      var data = await api('/api/console/presets');
      var presets = data.presets || [];
      var active = data.active || 'default';
      sel.innerHTML = presets.map(function(p) {
        return '<option value="' + escapeHtml(p.name) + '"' + (p.name === active ? ' selected' : '') + '>'
          + escapeHtml(p.label || p.name) + ' (' + (p.step_count || 0) + ' 步)</option>';
      }).join('');
    } catch(err) { sel.innerHTML = '<option>加载失败</option>'; }
  }

  async function switchToPreset(name) {
    try {
      await api('/api/console/presets/' + encodeURIComponent(name) + '/activate', { method: 'POST' });
      loadStepEditor();
      loadPresetSwitcher();
      toast('已切换到：' + name, 'success');
    } catch(err) { toast('切换失败：' + err.message, 'error'); }
  }

  async function newEmptyPreset() {
    var name = ($('preset-new-name-inline').value || '').trim();
    if (!name) { toast('请输入预设名称', 'error'); return; }
    if (!/^[a-z0-9_]+$/.test(name)) { toast('名称只能包含小写字母、数字、下划线', 'error'); return; }
    try {
      await api('/api/console/presets/' + encodeURIComponent(name), { method: 'POST', body: { name: name, steps: [], inherits: null, variables: {} } });
      toast('已创建空预设：' + name, 'success');
      await api('/api/console/presets/' + encodeURIComponent(name) + '/activate', { method: 'POST' });
      _currentSteps = [];
      $('preset-new-name-inline').value = '';
      $('preset-new-dialog').style.display = 'none';
      loadPresetSwitcher();
      renderStepList({});
    } catch(err) { toast('创建失败：' + err.message, 'error'); }
  }

  async function saveCurrentPreset() {
    var presetName = ($('preset-switcher').value || '').trim();
    if (!presetName) { toast('请先选择或创建一个预设', 'error'); return; }
    try {
      var body = { name: presetName, steps: _currentSteps, inherits: null, variables: {} };
      await api('/api/console/presets/' + encodeURIComponent(presetName), { method: 'POST', body: body });
      toast('已覆盖保存到 ' + presetName, 'success');
      loadPresetSwitcher();
    } catch(err) { toast('保存失败：' + err.message, 'error'); }
  }

  async function deleteCurrentPreset() {
    var presetName = ($('preset-switcher').value || '').trim();
    if (!presetName) return;
    if (presetName === 'default') { toast('不能删除默认预设', 'error'); return; }
    showConfirm('确定删除预设「' + presetName + '」？此操作不可撤销。', async function() {
      try {
        await api('/api/console/presets/' + encodeURIComponent(presetName), { method: 'DELETE' });
        toast('已删除：' + presetName, 'success');
        await api('/api/console/presets/default/activate', { method: 'POST' });
        loadPresetSwitcher();
        loadStepEditor();
      } catch(err) { toast('删除失败：' + err.message, 'error'); }
    });
  }

  function bindPhaseControls() {
    var toggle = $('phase-controls-toggle');
    var body = $('phase-controls-body');
    var chevron = $('phase-controls-chevron');
    if (!toggle || !body) return;
    toggle.addEventListener('click', function() {
      if (body.style.display === 'none') {
        body.style.display = 'block';
        if (chevron) chevron.textContent = '点击收起▲';
        loadStepEditor();
      } else {
        body.style.display = 'none';
        if (chevron) chevron.textContent = '点击展开▼';
      }
    });
    // buttons
    var addBuiltin = $('btn-step-add-builtin');
    if (addBuiltin) addBuiltin.addEventListener('click', addBuiltinStep);
    var builtinConfirm = $('btn-builtin-select-confirm');
    if (builtinConfirm) builtinConfirm.addEventListener('click', confirmAddBuiltin);
    var builtinClose = $('builtin-select-dialog-close');
    if (builtinClose) builtinClose.addEventListener('click', function() { $('builtin-select-dialog').style.display = 'none'; });
    var addCustom = $('btn-step-add-custom');
    if (addCustom) addCustom.addEventListener('click', function() {
      var dlg = $('step-add-dialog');
      if (dlg) dlg.style.display = dlg.style.display === 'none' ? 'block' : 'none';
    });
    var closeDlg = $('step-add-dialog-close');
    if (closeDlg) closeDlg.addEventListener('click', function() { $('step-add-dialog').style.display = 'none'; });
    var genBtn = $('btn-step-generate');
    if (genBtn) genBtn.addEventListener('click', generateStep);
    var addGen = $('btn-step-add-generated');
    if (addGen) addGen.addEventListener('click', addGeneratedStep);
    // step library
    bindStepLibrary();
    var libBtn = $('btn-step-library');
    if (libBtn) libBtn.addEventListener('click', function() {
      var m = $('step-library-modal');
      if (m) { m.style.display = m.style.display === 'none' ? 'block' : 'none'; if (m.style.display === 'block') loadStepLibrary(); }
    });
    var libClose = $('step-library-close');
    if (libClose) libClose.addEventListener('click', function() { $('step-library-modal').style.display = 'none'; });
    // 💾 保存 = overwrite current preset
    var saveCurr = $('btn-preset-save-curr');
    if (saveCurr) saveCurr.addEventListener('click', saveCurrentPreset);
    // 另存为… = open save-as dialog
    var saveAs = $('btn-preset-save-as');
    if (saveAs) saveAs.addEventListener('click', function() {
      var dlg = $('preset-save-dialog');
      if (dlg) dlg.style.display = dlg.style.display === 'none' ? 'block' : 'none';
    });
    var saveConfirm = $('btn-preset-save-confirm');
    if (saveConfirm) saveConfirm.addEventListener('click', saveStepsAsPreset);
    var saveClose = $('preset-save-dialog-close');
    if (saveClose) saveClose.addEventListener('click', function() { $('preset-save-dialog').style.display = 'none'; });
    // ➕ 新建 = inline input, not prompt()
    var newBtn = $('btn-preset-new');
    if (newBtn) newBtn.addEventListener('click', function() {
      var dlg = $('preset-new-dialog');
      if (dlg) dlg.style.display = dlg.style.display === 'none' ? 'block' : 'none';
    });
    var newConfirm = $('btn-preset-new-confirm');
    if (newConfirm) newConfirm.addEventListener('click', newEmptyPreset);
    var newClose = $('preset-new-dialog-close');
    if (newClose) newClose.addEventListener('click', function() { $('preset-new-dialog').style.display = 'none'; });
    // preset switcher
    var presetSel = $('preset-switcher');
    if (presetSel) presetSel.addEventListener('change', function() { switchToPreset(presetSel.value); });
    var delBtn = $('btn-preset-delete');
    if (delBtn) delBtn.addEventListener('click', deleteCurrentPreset);
    // load switcher on expand
    loadPresetSwitcher();
  }

  async function loadStepEditor() {
    try {
      // Load active preset steps
      var pData = await api('/api/console/presets');
      var active = pData.active || 'default';
      var presetData = await api('/api/console/presets/' + encodeURIComponent(active));
      var preset = presetData.preset || {};
      _currentSteps = Array.isArray(preset.steps) ? preset.steps : [];
      var pcData = await api('/api/console/phase-controls');
      _stepControlsCache = pcData.controls || {};
      renderStepList(_stepControlsCache);
    } catch(err) {
      var list = $('step-editor-list');
      if (list) list.textContent = '加载失败：' + err.message;
    }
  }

  function renderStepList(controls) {
    var list = $('step-editor-list');
    var summary = $('phase-controls-summary');
    if (!list) return;
    if (_currentSteps.length === 0) {
      list.innerHTML = '<div class="inbox-meta" style="padding:0.5rem">暂无步骤，请添加内置步骤或 AI 生成自定义步骤</div>';
      if (summary) summary.textContent = '空';
      return;
    }
    list.innerHTML = _currentSteps.map(function(step, idx) {
      var sid = step.id || '';
      var isBuiltin = step.type === 'builtin';
      var typeBadge = isBuiltin ? '<span class="badge-indigo">内置</span>'
        : '<span class="badge-indigo" style="background:var(--success-soft);color:var(--success)">自定义</span>';
      var label = step.label || sid;
      var desc = BUILTIN_DESCRIPTIONS[sid] || (step.description || '');
      var ctrl = controls[sid] || {};
      var enabled = step.enabled !== false && ctrl.control !== 'skip';
      var paused = step.pause_after || ctrl.control === 'pause_after';
      var rowStyle = enabled ? '' : 'opacity:0.4';
      return '<div class="step-editor-row card-glass" data-step-idx="' + idx + '" style="display:flex;align-items:center;gap:0.75rem;padding:0.75rem 1rem;margin-bottom:0.5rem;' + rowStyle + '">'
        + '<span style="cursor:grab;color:var(--muted);font-size:1.2rem">⋮⋮</span>'
        + typeBadge
        + '<span style="flex:1;min-width:0">'
        + '<span style="font-size:0.9rem;font-weight:600;display:block;color:var(--text)">' + escapeHtml(label) + '</span>'
        + (desc ? '<span class="text-muted" style="font-size:0.75rem;display:block;white-space:nowrap;overflow:hidden;text-overflow:ellipsis" title="' + escapeHtml(desc) + '">' + escapeHtml(desc) + '</span>' : '')
        + '</span>'
        + (isBuiltin ? '' : '<button class="btn-ghost tiny" data-edit-step="' + idx + '" title="编辑JSON">✏️</button>')
        + '<div style="display:flex;align-items:center;gap:1rem">'
        + '<label class="toggle-switch" style="margin:0" title="启用/禁用">'
        + '<input type="checkbox" data-step-enable="' + idx + '"' + (enabled ? ' checked' : '') + '>'
        + '<span class="toggle-track"></span></label>'
        + '<label style="display:' + (enabled ? 'inline-flex' : 'none') + ';align-items:center;gap:0.25rem;font-size:0.75rem;cursor:pointer;white-space:nowrap;color:var(--text-muted)" data-pause-wrap="' + idx + '" title="完成后暂停">'
        + '<input type="checkbox" data-step-pause="' + idx + '"' + (paused ? ' checked' : '') + '> ⏸ 暂停</label>'
        + '<div class="btn-group">'
        + '<button class="btn-ghost tiny" data-step-up="' + idx + '" title="上移" ' + (idx === 0 ? 'disabled' : '') + '>↑</button>'
        + '<button class="btn-ghost tiny" data-step-down="' + idx + '" title="下移" ' + (idx === _currentSteps.length - 1 ? 'disabled' : '') + '>↓</button>'
        + '</div>'
        + '<button class="btn-danger tiny" data-step-delete="' + idx + '" title="删除">✕</button>'
        + '</div></div>';
    }).join('');
    // summary
    if (summary) {
      var enabledCount = _currentSteps.filter(function(s) { return s.enabled !== false; }).length;
      summary.textContent = _currentSteps.length + ' 步，' + enabledCount + ' 启用';
    }
    // bind row buttons
    list.querySelectorAll('[data-step-delete]').forEach(function(btn) {
      btn.addEventListener('click', function() { deleteStep(parseInt(btn.dataset.stepDelete)); });
    });
    list.querySelectorAll('[data-step-up]').forEach(function(btn) {
      btn.addEventListener('click', function() { moveStep(parseInt(btn.dataset.stepUp), -1); });
    });
    list.querySelectorAll('[data-step-down]').forEach(function(btn) {
      btn.addEventListener('click', function() { moveStep(parseInt(btn.dataset.stepDown), 1); });
    });
    list.querySelectorAll('[data-step-enable]').forEach(function(cb) {
      cb.addEventListener('change', function() {
        var idx = parseInt(cb.dataset.stepEnable);
        _currentSteps[idx].enabled = cb.checked;
        renderStepList(controls);
      });
    });
    list.querySelectorAll('[data-step-pause]').forEach(function(cb) {
      cb.addEventListener('change', function() {
        var idx = parseInt(cb.dataset.stepPause);
        _currentSteps[idx].pause_after = cb.checked;
      });
    });
    list.querySelectorAll('[data-edit-step]').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var idx = parseInt(btn.dataset.editStep);
        editStepJson(idx);
      });
    });
  }

  function addBuiltinStep() {
    var usedIds = _currentSteps.map(function(s) { return s.id; });
    var available = BUILTIN_PHASES.filter(function(p) { return usedIds.indexOf(p) === -1; });
    if (available.length === 0) { toast('所有内置步骤已添加', 'info'); return; }
    // Show inline selector instead of prompt()
    var dlg = $('builtin-select-dialog');
    if (!dlg) return;
    var sel = $('builtin-select-options');
    if (!sel) return;
    sel.innerHTML = available.map(function(p) {
      return '<option value="' + escapeHtml(p) + '">' + escapeHtml(BUILTIN_LABELS[p] || p) + (BUILTIN_DESCRIPTIONS[p] ? ' — ' + escapeHtml(BUILTIN_DESCRIPTIONS[p]) : '') + '</option>';
    }).join('');
    dlg.style.display = 'block';
  }

  function confirmAddBuiltin() {
    var sel = $('builtin-select-options');
    if (!sel) return;
    var phase = sel.value;
    if (!phase) return;
    _currentSteps.push({
      id: phase, type: 'builtin', label: BUILTIN_LABELS[phase] || phase,
      enabled: true, pause_after: false
    });
    $('builtin-select-dialog').style.display = 'none';
    renderStepList(_stepControlsCache);
    toast('已添加：' + (BUILTIN_LABELS[phase] || phase), 'success');
  }

  // ── Step Library ──
  var _libSteps = [];
  var _libCardSize = 'm';  // s | m | l

  function bindStepLibrary() {
    var sizes = { s: '120px', m: '180px', l: '260px' };
    ['s','m','l'].forEach(function(sz) {
      var btn = $('lib-size-' + sz);
      if (btn) btn.addEventListener('click', function() {
        _libCardSize = sz;
        var grid = $('step-library-grid');
        if (grid) grid.style.gridTemplateColumns = 'repeat(auto-fill,minmax(' + sizes[sz] + ',1fr))';
        renderLibraryCards();
      });
    });
  }

  async function loadStepLibrary() {
    var grid = $('step-library-grid');
    if (!grid) return;
    try {
      var data = await api('/api/console/step-library');
      _libSteps = data.steps || [];
      renderLibraryCards();
    } catch(err) { grid.textContent = '加载失败：' + err.message; }
  }

  function renderLibraryCards() {
    var grid = $('step-library-grid');
    if (!grid || _libSteps.length === 0) { if (grid) grid.innerHTML = '<div class="inbox-meta" style="padding:0.5rem">步骤库为空</div>'; return; }
    var isSmall = _libCardSize === 's';
    grid.innerHTML = _libSteps.map(function(s, idx) {
      var isBuiltin = s.type === 'builtin';
      var color = isBuiltin ? 'var(--primary)' : 'var(--success)';
      var badgeCls = isBuiltin ? 'badge-indigo' : 'badge-indigo';
      var badgeStyle = isBuiltin ? '' : 'background:var(--success-soft);color:var(--success)';
      var label = s.label || s.id;
      var desc = s.description || '';
      var actionCount = Array.isArray(s.actions) ? s.actions.length : 0;
      var actionBadge = actionCount > 0 ? '<span class="badge-indigo" style="background:var(--primary-soft);color:var(--primary);margin-left:0.25rem">' + actionCount + ' 动作</span>' : '';
      return '<div class="card-glass lib-card" data-lib-idx="' + idx + '" style="cursor:pointer;padding:1rem;border-left:4px solid ' + color + ';transition:transform 0.2s">'
        + '<div style="display:flex;justify-content:space-between;align-items:flex-start;gap:0.5rem">'
        + '<strong style="font-size:0.9rem;color:var(--text)">' + escapeHtml(label) + '</strong>'
        + '</div>'
        + (isSmall ? '' : '<div class="text-muted" style="font-size:0.75rem;margin-top:0.5rem;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden">' + escapeHtml(desc) + '</div>')
        + '<div style="margin-top:1rem;display:flex;gap:0.4rem;align-items:center">'
        + '<span class="' + badgeCls + '" style="font-size:0.7rem;' + badgeStyle + '">' + (isBuiltin ? '内置' : '自定义') + '</span>'
        + actionBadge
        + '<span style="flex:1"></span>'
        + '<div class="btn-group">'
        + '<button class="btn-primary tiny" data-lib-add="' + idx + '" title="添加">➕</button>'
        + (isBuiltin ? '' : '<button class="btn-danger tiny" data-lib-del="' + idx + '" title="删除">✕</button>')
        + '</div></div></div>';
    }).join('');
    // click card → show detail
    grid.querySelectorAll('.lib-card').forEach(function(card) {
      card.addEventListener('click', function(e) {
        if (e.target.closest('button')) return; // don't trigger on + button
        var idx = parseInt(card.dataset.libIdx);
        showLibraryDetail(idx);
      });
    });
    // add button
    grid.querySelectorAll('[data-lib-add]').forEach(function(btn) {
      btn.addEventListener('click', function(e) {
        e.stopPropagation();
        var idx = parseInt(btn.dataset.libAdd);
        var step = _libSteps[idx];
        if (!step) return;
        addStepFromLibrary(step);
      });
    });
    // delete button on cards
    grid.querySelectorAll('[data-lib-del]').forEach(function(btn) {
      btn.addEventListener('click', function(e) {
        e.stopPropagation();
        var idx = parseInt(btn.dataset.libDel);
        var step = _libSteps[idx];
        if (!step) return;
        deleteStepFromLibrary(step);
      });
    });
  }

  async function deleteStepFromLibrary(step) {
    showConfirm('从步骤库删除「' + (step.label || step.id) + '」？', async function() {
      try {
        await api('/api/console/step-library/' + encodeURIComponent(step.id), { method: 'DELETE' });
        toast('已从库中删除', 'success');
        loadStepLibrary();
      } catch(err) { toast('删除失败：' + err.message, 'error'); }
    });
  }

  function showLibraryDetail(idx) {
    var s = _libSteps[idx];
    if (!s) return;
    var detail = $('step-library-detail');
    if (!detail) return;
    var actions = Array.isArray(s.actions) ? s.actions : [];
    var actionsHtml = actions.length > 0
      ? '<div style="margin-top:0.3rem"><strong>Actions (' + actions.length + '):</strong><pre style="font-size:0.7rem;margin:0.2rem 0;white-space:pre-wrap">' + escapeHtml(JSON.stringify(actions, null, 2)) + '</pre></div>'
      : '';
    detail.innerHTML =
      '<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:1rem"><strong style="font-size:1.1rem;color:var(--text)">' + escapeHtml(s.label || s.id) + '</strong>'
      + '<button class="btn-ghost tiny" onclick="document.getElementById(\'step-library-detail\').style.display=\'none\'">✕</button></div>'
      + '<div class="text-muted" style="margin-bottom:0.75rem">ID: ' + escapeHtml(s.id) + ' · 类型: ' + escapeHtml(s.type || 'custom') + '</div>'
      + (s.description ? '<div style="margin-bottom:1rem;line-height:1.5;color:var(--text)">' + escapeHtml(s.description) + '</div>' : '')
      + '<div class="card-glass" style="padding:0.75rem;margin-bottom:1rem;font-size:0.85rem">'
      + '<div><span class="text-muted">输入:</span> ' + escapeHtml(s.input || '{prev_output}') + '</div>'
      + '<div style="margin-top:0.25rem"><span class="text-muted">输出:</span> ' + escapeHtml(s.output || '—') + '</div>'
      + '</div>'
      + actionsHtml
      + '<div style="margin-top:1.5rem;display:flex;gap:0.75rem">'
      + '<button class="btn-primary" style="flex:1" onclick="var s=_libSteps[' + idx + ']; if(s)addStepFromLibrary(s)">➕ 添加到预设</button>'
      + (s.type !== 'builtin' ? '<button class="btn-danger" onclick="deleteStepFromLibrary(_libSteps[' + idx + '])">🗑 删除</button>' : '')
      + '</div>';
    detail.style.display = 'block';
  }

  function addStepFromLibrary(step) {
    if (!step) return;
    var already = _currentSteps.find(function(s) { return s.id === step.id; });
    if (already) { toast('步骤「' + (step.label || step.id) + '」已在列表中', 'info'); return; }
    _currentSteps.push({
      id: step.id, type: step.type || 'custom', label: step.label || step.id,
      description: step.description || '',
      enabled: true, pause_after: false,
      actions: step.actions || null
    });
    renderStepList(_stepControlsCache);
    toast('已添加：' + (step.label || step.id), 'success');
  }

  async function saveStepToLibrary(step) {
    try {
      await api('/api/console/step-library', { method: 'POST', body: step });
    } catch(err) { /* silent */ }
  }

  async function generateStep() {
    var desc = ($('step-add-description').value || '').trim();
    if (!desc) { toast('请输入步骤描述', 'error'); return; }
    var statusEl = $('step-generate-status');
    var previewEl = $('step-generate-preview');
    var addBtn = $('btn-step-add-generated');
    var genBtn = $('btn-step-generate');
    if (statusEl) statusEl.textContent = '生成中…';
    genBtn.disabled = true;
    try {
      var existing = _currentSteps.map(function(s) { return s.id + ' (' + (s.label || '') + ')'; }).join(', ');
      var data = await api('/api/console/steps/generate', { method: 'POST', body: { description: desc, existing_steps: existing } });
      if (data.ok && data.step) {
        _generatedStep = data.step;
        // Auto-save to step library
        saveStepToLibrary(data.step);
        if (previewEl) {
          previewEl.textContent = JSON.stringify(data.step, null, 2);
          previewEl.style.display = 'block';
        }
        if (addBtn) addBtn.style.display = '';
        if (statusEl) statusEl.textContent = '✅ ' + (data.message || '生成成功');
      } else {
        if (previewEl) {
          previewEl.textContent = data.raw || data.message || '生成失败';
          previewEl.style.display = 'block';
        }
        if (statusEl) statusEl.textContent = '❌ ' + (data.message || '失败');
      }
    } catch(err) {
      if (statusEl) statusEl.textContent = '❌ ' + err.message;
    } finally { genBtn.disabled = false; }
  }

  function addGeneratedStep() {
    if (!_generatedStep) return;
    _currentSteps.push(_generatedStep);
    _generatedStep = null;
    $('step-generate-preview').style.display = 'none';
