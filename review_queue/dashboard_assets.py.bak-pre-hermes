"""Static assets (CSS, HTML body template, JS) for the ANP Local Studio dashboard.

These are kept in their own module so :mod:`review_queue.human_review` stays
focused on routing/business logic. Templates use ``__PLACEHOLDER__`` style
markers consumed via :py:meth:`str.replace` to avoid f-string brace conflicts
with embedded CSS / JS.
"""

from __future__ import annotations


DASHBOARD_CSS = """

:root {
  --bg: #030712; /* Extreme dark */
  --panel: #0f172a;
  --border: rgba(255, 255, 255, 0.05);
  --text: #f8fafc;
  --text-muted: #94a3b8;
  --primary: #6366f1; /* Indigo */
  --primary-glow: rgba(99, 102, 241, 0.4);
  --accent: #a5b4fc;
  --grid-line: rgba(255, 255, 255, 0.03);
}


[data-theme='dark'] {
  --bg: #0b0f1a;
  --panel: #111827;
  --panel-soft: #0f172a;
  --border: #334155;
  --text: #f1f5f9;
  --text-muted: #94a3b8;
  --primary: #6366f1;
  --primary-strong: #818cf8;
  --primary-soft: rgba(99, 102, 241, 0.1);
  --success: #10b981;
  --success-soft: rgba(16, 185, 129, 0.1);
  --warning: #f59e0b;
  --warning-soft: rgba(245, 158, 11, 0.1);
  --danger: #f43f5e;
  --danger-soft: rgba(244, 63, 94, 0.1);
  --info: #3b82f6;
  --sidebar-bg: #020617;
  --sidebar-text: #94a3b8;
  --sidebar-active: #ffffff;
  --card-bg: rgba(30, 41, 59, 0.7);
}

* { box-sizing: border-box; }
html, body { margin: 0; padding: 0; background: var(--bg); transition: background-color 0.3s, color 0.3s; }
body {
  font-family: 'Inter', 'Space Grotesk', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
  color: var(--text);
  line-height: 1.6;
  -webkit-font-smoothing: antialiased;
}
.layout { display: flex; min-height: 100vh; }

.sidebar {
  width: 240px;
  background: #0f172a; /* Deep Slate/Navy */
  color: #94a3b8;
