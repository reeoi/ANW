      return;
    }
    target.classList.remove('empty');
    const maxTokens = rows.reduce((acc, r) => Math.max(acc, r.tokens || 0), 0) || 1;
    const bars = rows.map((row) => {
      const height = ((row.tokens || 0) / maxTokens) * 100;
      const tooltip = (row.day || '') + '：' + (row.tokens || 0).toLocaleString() +
        ' tokens · ¥' + ((row.cost || 0).toFixed ? (row.cost || 0).toFixed(4) : row.cost || 0) +
        ' · ' + (row.calls || 0) + ' 次';
      return '<div class="bar" style="height:' + Math.max(height, 4) + '%" data-tooltip="' + escapeHtml(tooltip) + '"></div>';
    }).join('');
    target.innerHTML = '<div class="spark">' + bars + '</div>' +
      '<div class="meta">最早 ' + escapeHtml(rows[0].day || '') + ' · 最新 ' + escapeHtml(rows[rows.length - 1].day || '') + '</div>';
