  // ---------- Monitor ----------
  let monitorTimer = null;

  function formatBytes(bytes) {
    if (!bytes && bytes !== 0) return '—';
    const units = ['B', 'KB', 'MB', 'GB'];
    let value = Number(bytes);
    let unit = 0;
    while (value >= 1024 && unit < units.length - 1) { value /= 1024; unit += 1; }
    return value.toFixed(value >= 100 || unit === 0 ? 0 : 1) + ' ' + units[unit];
  }

  function progressClass(pct) {
    if (pct >= 90) return 'bad';
    if (pct >= 70) return 'warn';
    return '';
  }

  async function loadMonitor() {
    try {
      const data = await api('/api/monitor');
      renderMonitorKpis(data);
      renderMonitorQuota(data);
      renderMonitorDaily(data.daily_usage || []);
      renderMonitorEvents(data.recent_events || []);
      renderMonitorErrors(data.recent_errors || []);
      renderMonitorHealth(data);
    } catch (err) {
      toast('监控数据加载失败：' + err.message, 'error');
    }
  }

  function renderMonitorKpis(data) {
    const usage = data.usage || {};
    const d1 = usage.d1 || {}; const d7 = usage.d7 || {}; const d30 = usage.d30 || {};
    const events1 = data.events && data.events.d1 ? data.events.d1 : {};
    const generated24h = (events1.generate && events1.generate.success) || 0;
    const reviewed24h = Object.values(events1.review || {}).reduce((a, b) => a + b, 0);
    const published24h = (events1.publish && (events1.publish.published || events1.publish.success)) || 0;
    const items = [
      { label: '24h 调用次数', value: d1.calls || 0, cls: '' },
      { label: '24h tokens', value: (d1.total_tokens || 0).toLocaleString(), cls: '' },
      { label: '24h 估算成本', value: '¥' + (d1.cost_cny || 0).toFixed(4), cls: 'ok' },
      { label: '7d 估算成本', value: '¥' + (d7.cost_cny || 0).toFixed(2), cls: '' },
      { label: '30d 估算成本', value: '¥' + (d30.cost_cny || 0).toFixed(2), cls: '' },
      { label: '24h 失败请求', value: d1.failures || 0, cls: (d1.failures || 0) > 0 ? 'bad' : 'ok' },
      { label: '24h 生成成功', value: generated24h, cls: '' },
      { label: '24h 审核', value: reviewed24h, cls: '' },
      { label: '24h 发布', value: published24h, cls: '' },
    ];
    $('monitor-kpis').innerHTML = items.map((item) =>
      '<div class="card ' + item.cls + '">' +
      '<div class="label">' + escapeHtml(item.label) + '</div>' +
      '<div class="value">' + escapeHtml(item.value) + '</div></div>'
    ).join('');
  }

  function renderMonitorQuota(data) {
    const target = $('monitor-quota');
    const limits = data.limits || {};
    const monthlyPct = Math.min(100, limits.monthly_budget_used_pct || 0);
    const dailyPct = Math.min(100, limits.daily_token_used_pct || 0);
    const monthlyCls = progressClass(monthlyPct);
    const dailyCls = progressClass(dailyPct);
    const html =
      '<div class="bar-row"><span>月度预算（30 日）</span>' +
      '<div class="progress ' + monthlyCls + '"><span style="width:' + monthlyPct + '%"></span></div>' +
      '<span>¥' + (limits.spent_30d_cny || 0).toFixed(2) + ' / ¥' + (limits.monthly_budget_cny || 0) + '</span>' +
      '</div>' +
      '<div class="bar-row"><span>每日 token 上限</span>' +
      '<div class="progress ' + dailyCls + '"><span style="width:' + dailyPct + '%"></span></div>' +
      '<span>' + (limits.tokens_24h || 0).toLocaleString() + ' / ' + (limits.daily_token_limit || 0).toLocaleString() + '</span>' +
      '</div>';
    target.classList.remove('empty');
